{
	"name": "agentfabric",
	"type": "module",
	"version": "0.0.2",
	"description": "AgentFabric CLI - A minimal process management layer for running, monitoring, and controlling the AgentFabric runtime.",
	"license": "Apache-2.0",
	"bin": {
		"afabric": "bin/agentfabric",
		"agentfabric": "bin/agentfabric"
	},
	"publishConfig": {
		"access": "public"
	},
	"author": {
		"name": "mdirshadengineer",
		"email": "mdirshadengineer+github@gmail.com",
		"url": "https://mdirshad.vercel.app"
	},
	"repository": {
		"directory": "packages/cli",
		"type": "git"
	},
	"engines": {
		"node": ">=24"
	},
	"files": [
		"dist",
		"bin",
		"README.md",
		"CHANGELOG.md",
		"package.json"
	],
	"scripts": {
		"start": "node ./bin/agentfabric",
		"dev": "tsx watch src/dev/main.ts",
		"build-ui": "pnpm --filter agentfabric-web ui-build",
		"compile-cli": "shx rm -rf dist && tsc -b tsconfig.build.json",
		"sync-ui": "shx rm -rf dist/ui && shx mkdir -p dist/ui && shx cp -r ../../web/build/. dist/ui",
		"build": "pnpm run build-ui && pnpm run compile-cli && pnpm run sync-ui",
		"db:push": "drizzle-kit push --config src/drizzle.config.ts",
		"db:pull": "drizzle-kit pull --config src/drizzle.config.ts",
		"db:drop": "drizzle-kit drop --config src/drizzle.config.ts",
		"db:studio": "drizzle-kit studio --config src/drizzle.config.ts",
		"db:migrate": "drizzle-kit migrate --config src/drizzle.config.ts",
		"db:generate": "drizzle-kit generate --config src/drizzle.config.ts",
		"lint": "biome check",
		"format": "biome format --write",
		"typecheck": "tsc --noEmit",
		"clean": "shx rm -rf node_modules .turbo dist"
	},
	"dependencies": {
		"@better-auth/api-key": "1.6.10",
		"@fastify/autoload": "6.3.1",
		"@fastify/http-proxy": "11.4.4",
		"@fastify/rate-limit": "10.3.0",
		"@fastify/static": "9.1.3",
		"arktype": "catalog:",
		"better-auth": "catalog:",
		"drizzle-arktype": "catalog:",
		"drizzle-orm": "catalog:",
		"fastify": "5.8.5",
		"fastify-plugin": "5.1.0",
		"postgres": "catalog:",
		"reflect-metadata": "0.2.2",
		"semver": "7.7.4",
		"source-map-support": "0.5.21",
		"tsyringe": "4.10.0"
	},
	"devDependencies": {
		"@types/node": "catalog:",
		"dotenv": "17.4.2",
		"drizzle-kit": "catalog:",
		"pino": "10.3.1",
		"pino-pretty": "13.1.3",
		"tsx": "catalog:",
		"typescript": "catalog:"
	}
}
