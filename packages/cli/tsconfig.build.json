{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"outDir": "dist",
		"declaration": false,
		"skipLibCheck": true,
		"sourceMap": false,
		"removeComments": true,
		"tsBuildInfoFile": "node_modules/.cache/tsconfig.build.tsbuildinfo"
	},
	"exclude": [
		"dist",
		"migrations",
		"node_modules",
		"src/dev",
		"src/drizzle.config.ts"
	]
}
